<% content_for :title, "devopsellence | github actions setup" %>
<% content_for :body_class, "public-page" %>

<div class="page-shell">
  <main class="page setup-page">

    <p class="setup-breadcrumb">devopsellence / github actions setup</p>

    <% if flash[:alert] %>
      <p class="flash flash--alert"><%= flash[:alert] %></p>
    <% end %>

    <% if @token %>

      <%# ── State 2: token generated ── %>

      <h1 class="setup-title">
        <span class="setup-title__check">✓</span> ready to deploy
      </h1>

      <div class="setup-steps">

        <div class="setup-step">
          <p class="setup-step__label">1 — add secret to github</p>
          <p class="setup-step__body">
            Go to your repository → <strong>Settings → Secrets and variables → Actions</strong>
            and add a new <strong>repository secret</strong>:
          </p>
          <p class="setup-step__body" style="margin-top: 8px;">
            Use an environment secret only if you want GitHub Environment rules like approvals
            or separate staging and production tokens.
          </p>
          <div class="command-panel" style="margin-top: 12px;">
            <div class="command-entry command-entry--copyable">
              <div class="command-line">
                <span class="command-prompt">name</span>
                <code>DEVOPSELLENCE_TOKEN</code>
              </div>
            </div>
            <div class="command-entry command-entry--copyable">
              <div class="command-line">
                <span class="command-prompt">value</span>
                <code id="token-value"><%= @token %></code>
              </div>
              <button class="copy-button" onclick="copyText('token-value', this)">copy</button>
            </div>
          </div>
          <p class="setup-once-warning">token value shown once — copy it now</p>
        </div>

        <div class="setup-step">
          <p class="setup-step__label">2 — add workflow file</p>
          <p class="setup-step__body">
            Create <code>.github/workflows/deploy.yml</code> in your repository:
          </p>
          <div class="config-block-wrap" style="margin-top: 12px;">
            <div class="config-block-label setup-file-label">
              <span>.github/workflows/deploy.yml</span>
              <button class="copy-button" onclick="copyText('yaml-value', this)">copy</button>
            </div>
            <pre class="config-block" id="yaml-value">on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    env:
      DEVOPSELLENCE_ENV_VARS: ${{ vars.DEVOPSELLENCE_ENV_VARS }}
      DEVOPSELLENCE_SECRETS: ${{ secrets.DEVOPSELLENCE_SECRETS }}
    steps:
      - uses: actions/checkout@v4
      - uses: devopsellence/deploy-action@v1
        with:
          token: ${{ secrets.DEVOPSELLENCE_TOKEN }}
          organization: <%= @organization %>
          project: <%= @project %>
          environment: <%= @environment %></pre>
          </div>
        </div>

        <div class="setup-step">
          <p class="setup-step__label">3 — optional runtime vars and secrets</p>
          <p class="setup-step__body">
            To manage runtime config without the CLI, add a repository variable named
            <strong>DEVOPSELLENCE_ENV_VARS</strong> and a repository secret named
            <strong>DEVOPSELLENCE_SECRETS</strong>. Set each one to JSON. A flat object
            applies to every configured service. A scoped object can use
            <strong>all</strong>, <strong>web</strong>, and <strong>worker</strong>.
          </p>
        </div>

        <p class="setup-done">
          push to <code>main</code> and your app deploys. that's it.
        </p>

      </div>

    <% else %>

      <%# ── State 1: project creation form ── %>

      <h1 class="setup-title">set up github actions deploy</h1>

      <p class="setup-lead">
        Name your project and we'll provision everything. You'll get a deploy
        token and a workflow snippet — no CLI needed.
      </p>

      <%= form_with url: setup_github_actions_path, method: :post, class: "setup-form" do %>
        <div class="field">
          <%= label_tag :organization_name, "Organization" %>
          <%= text_field_tag :organization_name, params[:organization_name].presence || Organization::DEFAULT_NAME,
                required: true,
                class: "input" %>
        </div>
        <div class="field">
          <%= label_tag :project_name, "Project name" %>
          <%= text_field_tag :project_name, params[:project_name],
                required: true,
                autofocus: true,
                placeholder: "my-app",
                class: "input" %>
        </div>
        <div class="field">
          <%= label_tag :environment_name, "Environment" %>
          <%= text_field_tag :environment_name, params[:environment_name].presence || Setup::GithubActionsController::DEFAULT_ENVIRONMENT_NAME,
                required: true,
                class: "input" %>
        </div>
        <%= button_tag "create project & get token →", type: :submit, class: "button button--primary" %>
      <% end %>

    <% end %>

  </main>
</div>

<script>
  function copyText(elementId, button) {
    const text = document.getElementById(elementId).textContent.trim();
    navigator.clipboard.writeText(text).then(function() {
      const original = button.textContent;
      button.textContent = "copied";
      setTimeout(function() { button.textContent = original; }, 1800);
    });
  }
</script>

<style>
  .setup-page {
    padding-top: 48px;
    max-width: 600px;
  }

  .setup-breadcrumb {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.74rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .setup-title {
    margin: 0 0 20px;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .setup-title__check {
    color: var(--accent);
  }

  .setup-lead {
    color: var(--muted-light);
    font-size: 0.96rem;
    line-height: 1.75;
    font-weight: 300;
    margin-bottom: 24px;
  }

  .setup-form {
    display: grid;
    gap: 14px;
    max-width: 360px;
  }

  .setup-steps {
    display: grid;
    gap: 32px;
  }

  .setup-step__label {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--prompt);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .setup-step__body {
    color: var(--muted-light);
    font-size: 0.92rem;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 0;
  }

  .setup-step__body strong {
    color: var(--text);
    font-weight: 500;
  }

  .setup-once-warning {
    margin-top: 8px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.76rem;
    color: var(--yellow);
  }

  .setup-file-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .setup-done {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .setup-done code {
    color: var(--muted-light);
  }
</style>

        <div class="article-diagram-arrow-group article-diagram-arrow-group--wide">
          <div class="article-diagram-arrow">&darr;</div>
          <div class="article-diagram-arrow-label">Publishes artifacts to GCP. Not in the runtime path.</div>
        </div>
      </div>
      <div class="article-diagram-row article-diagram-row--services">
        <div class="article-diagram-box article-diagram-box--green">
